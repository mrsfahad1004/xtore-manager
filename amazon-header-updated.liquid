<script>
fetch('/cart.js').then(function(r){return r.json()}).then(function(j){
  var count = j.item_count;
  document.querySelectorAll('.xt-cart-count').forEach(function(el){ el.textContent = count; });
  document.querySelectorAll('#xtHeaderCartCount').forEach(function(el){ el.textContent = count; });
}).catch(function(){});

(function(){
  var wrap = document.getElementById('xtMegaWrap');
  var btn = document.getElementById('xtAllBtn');
  var menu = document.getElementById('xtMegaMenu');
  if (!wrap || !btn || !menu) return;

  function positionMenu() {
    var rect = btn.getBoundingClientRect();
    menu.style.top = rect.bottom + 'px';
    menu.style.left = '0px';
    menu.style.width = '100vw';
    menu.style.maxWidth = '100vw';
  }

  function openMenu() {
    positionMenu();
    wrap.classList.add('is-open');
    btn.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    wrap.classList.remove('is-open');
    btn.setAttribute('aria-expanded', 'false');
  }

  btn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    if (wrap.classList.contains('is-open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  var hoverTimeout;
  wrap.addEventListener('mouseenter', function() {
    clearTimeout(hoverTimeout);
    openMenu();
  });
  wrap.addEventListener('mouseleave', function() {
    hoverTimeout = setTimeout(function() {
      closeMenu();
    }, 300);
  });

  document.addEventListener('click', function(e) {
    if (!wrap.contains(e.target)) {
      closeMenu();
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeMenu();
    }
  });

  window.addEventListener('scroll', function() {
    if (wrap.classList.contains('is-open')) {
      positionMenu();
    }
  }, {passive: true});
})();
</script>

