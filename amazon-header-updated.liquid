          <span class="xt-top-link-main">Orders</span>
        </a>
        <a href="/cart" class="xt-cart">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
          <span class="xt-cart-count" id="xtCartCount">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main Header: Logo + Deliver + All + Search -->
  <div class="xt-main-header">
    <div class="page-width">
      <!-- Logo -->
      <div class="xt-logo">
        <a href="{{ routes.root_url }}">
          <img src="{{ 'xtore-logo.jpg' | asset_url }}" alt="Xtore" style="height:64px;width:auto;">
        </a>
      </div>

      <!-- Deliver to -->
      <div class="xt-deliver">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div>
          <span class="xt-deliver-loc">Deliver to</span>
          <span class="xt-deliver-text">Worldwide</span>
        </div>
      </div>

      <!-- Search Bar -->
      <form action="/search" method="get" class="xt-search">
        <select name="type" class="xt-search-category">
          <option value="product">All</option>
          {%- for link in main_menu.links -%}
            <option value="product">{{ link.title }}</option>
          {%- endfor -%}
        </select>
        <input type="text" name="q" placeholder="Search Xtore" class="xt-search-input" autocomplete="off">
        <button type="submit" class="xt-search-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="#060000" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        </button>
      </form>

      <!-- Account, Orders, Cart -->
      <div class="xt-header-actions">
        <a href="/account" class="xt-header-action">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="xt-header-action-label">Account</span>
          <span class="xt-header-action-sub">&amp; Lists</span>
        </a>
        <a href="/account" class="xt-header-action">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span class="xt-header-action-label">Your</span>
          <span class="xt-header-action-sub">Orders</span>
        </a>
        <a href="/cart" class="xt-header-action xt-header-cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
          <span class="xt-header-cart-count" id="xtHeaderCartCount">{{ cart.item_count }}</span>
          <span class="xt-header-action-label">Cart</span>
        </a>
      </div>
    </div>
  </div>

