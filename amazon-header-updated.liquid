{%- style -%}
/* === AMAZON STYLE HEADER FOR XTORE === */
.xtore-header * { margin: 0; padding: 0; box-sizing: border-box; }

/* Top Utility Bar */
.xt-top-bar {
  background: #060000;
  padding: 6px 0;
  font-size: 13px;
}
.xt-top-bar .page-width {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.xt-top-right {
  display: flex;
  align-items: center;
  gap: 18px;
}
.xt-top-link {
  color: #fff;
  text-decoration: none;
  font-size: 13px;
  white-space: nowrap;
  cursor: pointer;
}
.xt-top-link:hover { color: #F5B904; }
.xt-top-link-sub {
  font-size: 11px;
  color: #aaa;
  display: block;
  line-height: 1.2;
}
.xt-top-link-main {
  font-weight: 600;
  font-size: 13px;
  display: block;
  line-height: 1.2;
}
.xt-cart {
  display: flex;
  align-items: center;
  gap: 4px;
  color: #fff;
  text-decoration: none;
  position: relative;
}
.xt-cart:hover { color: #F5B904; }
.xt-cart-count {
  position: absolute;
  top: -6px;
  right: -2px;
  background: #F5B904;
  color: #060000;
  font-size: 11px;
  font-weight: 800;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Main Header - Logo + Deliver + Search in ONE line */
.xt-main-header {
  background: #0d0d0d;
  padding: 12px 0;
}
.xt-main-header .page-width {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* Logo */
.xt-logo {
  flex-shrink: 0;
  margin-left: 8px;
}
.xt-logo a {
  text-decoration: none;
  display: flex;
  align-items: center;
}
.xt-logo-text {
  font-size: 28px;
  font-weight: 900;
  color: #F5B904;
  letter-spacing: -1px;
  white-space: nowrap;
  line-height: 1;
}
.xt-logo-text span {
  color: #fff;
  font-weight: 300;
}
.xt-logo-tagline {
  font-size: 9px;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 2px;
  display: block;
  margin-top: -2px;
}

/* Deliver */
.xt-deliver {
  display: flex;
  align-items: center;
  gap: 4px;
  color: #ccc;
  cursor: pointer;
  flex-shrink: 0;
  padding: 6px 10px;
  border: 1px solid transparent;
  border-radius: 6px;
  transition: border-color 0.2s;
}
.xt-deliver:hover { color: #F5B904; border-color: rgba(255,255,255,0.2); }
.xt-deliver-loc {
  font-size: 11px;
  color: #aaa;
  display: block;
  line-height: 1.2;
}
.xt-deliver-text {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  display: block;
  line-height: 1.2;
}

/* Hamburger / All Menu */
.xt-all-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  color: #fff;
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  padding: 8px 10px;
  border: 1px solid transparent;
  border-radius: 6px;
  cursor: pointer;
  flex-shrink: 0;
  transition: border-color 0.2s;
}
.xt-all-btn:hover { border-color: #fff; }
.xt-hamburger {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.xt-hamburger span {
  display: block;
  width: 18px;
  height: 2px;
  background: #fff;
  border-radius: 1px;
}

/* Search Bar */
.xt-search {
  flex: 1;
  display: flex;
  height: 48px;
  border-radius: 8px;
  overflow: hidden;
}
.xt-search-category {
  padding: 0 10px;
  background: #e8e8e8;
  border: none;
  font-size: 12px;
  color: #555;
  cursor: pointer;
  min-width: 60px;
  border-right: 1px solid #cdcdcd;
}
.xt-search-input {
  flex: 1;
  padding: 0 15px;
  border: none;
  font-size: 15px;
  outline: none;
  background: #fff;
  color: #111;
}
.xt-search-input::placeholder { color: #999; }
.xt-search-btn {
  width: 50px;
  background: #F5B904;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.xt-search-btn:hover { background: #e6ab00; }
.xt-search-btn svg { width: 22px; height: 22px; }

/* Header Right Actions */
.xt-header-actions {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.xt-header-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
  text-decoration: none;
  padding: 6px 8px;
  border: 1px solid transparent;
  border-radius: 6px;
  transition: border-color 0.2s;
  white-space: nowrap;
  position: relative;
}
.xt-header-action:hover { border-color: rgba(255,255,255,0.3); color: #F5B904; }
.xt-header-action svg { width: 24px; height: 24px; flex-shrink: 0; }
.xt-header-action-label {
  font-size: 11px;
  color: #ccc;
  line-height: 1.2;
  margin-top: 2px;
}
.xt-header-action:hover .xt-header-action-label { color: #F5B904; }
.xt-header-action-sub {
  font-size: 10px;
  color: #888;
  line-height: 1.1;
}
.xt-header-action:hover .xt-header-action-sub { color: #F5B904; }
.xt-header-cart {
  position: relative;
}
.xt-header-cart-count {
  position: absolute;
  top: -2px;
  right: 0px;
  background: #F5B904;
  color: #060000;
  font-size: 11px;
  font-weight: 800;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Bottom Nav */
.xt-bottom-nav {
  background: #131313;
  padding: 6px 0;
  border-top: 1px solid #222;
}
.xt-bottom-nav .page-width {
  display: flex;
  align-items: center;
  gap: 0;
  padding-left: 10px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.xt-bottom-nav::-webkit-scrollbar { display: none; }
.xt-nav-link {
  color: #F5B904;
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  padding: 6px 14px;
  white-space: nowrap;
  border: 1px solid transparent;
  border-radius: 6px;
  transition: all 0.2s;
}
.xt-nav-link:hover {
  color: #fff;
  border-color: rgba(245,185,4,0.5);
  background: rgba(245,185,4,0.1);
}
.xt-nav-link.active {
  color: #fff;
  font-weight: 700;
  background: rgba(245,185,4,0.15);
  border-color: rgba(245,185,4,0.3);
}

/* All Button + Mega Dropdown */
.xt-all-mega-wrap {
  position: relative;
}
.xt-all-toggle {
  background: none;
  border: none;
  font-family: inherit;
  font-size: 13px;
  cursor: pointer;
  line-height: 1.2;
}
.xt-all-trigger {
  display: flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  -webkit-user-select: none;
  user-select: none;
}
.xt-mega-menu {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  background: #1a1a1a;
  border: 1px solid #333;
  border-radius: 0 0 8px 8px;
  padding: 16px 0;
  min-width: 100%;
  max-width: 100vw;
  z-index: 10000;
  box-shadow: 0 8px 30px rgba(0,0,0,0.6);
}
.xt-all-mega-wrap.is-open .xt-mega-menu {
  display: block;
}
@media (min-width: 1200px) {
  .xt-mega-menu { min-width: 1000px; }
}
.xt-mega-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4px 20px;
  padding: 0 16px;
  max-height: 450px;
  overflow-y: auto;
}
.xt-mega-inner::-webkit-scrollbar { width: 6px; }
.xt-mega-inner::-webkit-scrollbar-track { background: #222; border-radius: 3px; }
.xt-mega-inner::-webkit-scrollbar-thumb { background: #555; border-radius: 3px; }
.xt-mega-col {
  min-width: 0;
  padding: 4px 0;
  border-right: 1px solid #2a2a2a;
}
.xt-mega-col:last-child { border-right: none; }
.xt-mega-col h4 {
  color: #F5B904;
  font-size: 13px;
  font-weight: 700;
  padding: 4px 10px 8px;
  border-bottom: 1px solid #333;
  margin-bottom: 6px;
}
.xt-mega-item {
  padding: 0;
}
.xt-mega-parent {
  display: block;
  color: #fff;
  text-decoration: none;
  font-size: 12px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 4px;
  transition: background 0.15s;
}
.xt-mega-parent:hover {
  background: rgba(245,185,4,0.15);
  color: #F5B904;
}
.xt-mega-sub {
  padding: 2px 0 6px 18px;
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}
.xt-mega-sub a {
  display: block;
  color: #bbb;
  text-decoration: none;
  font-size: 11px;
  padding: 2px 10px;
  border-radius: 3px;
  transition: all 0.15s;
  white-space: nowrap;
}
.xt-mega-sub a:hover {
  color: #F5B904;
  background: rgba(245,185,4,0.1);
}

/* Hide old top bar */
.xt-top-bar { display: none; }

/* Mobile */
.xt-mobile-header {
  display: none;
  background: #060000;
  padding: 10px 15px;
  align-items: center;
  gap: 10px;
}
.xt-mobile-hamburger {
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
}
.xt-mobile-hamburger span {
  display: block;
  width: 20px;
  height: 2px;
  background: #fff;
  margin: 4px 0;
  border-radius: 1px;
}
.xt-mobile-logo { flex: 1; }
.xt-mobile-logo a {
  font-size: 20px;
  font-weight: 900;
  color: #F5B904;
  text-decoration: none;
}
.xt-mobile-logo a span { color: #fff; font-weight: 300; }
.xt-mobile-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}
.xt-mobile-actions a { color: #fff; position: relative; }
.xt-mobile-search {
  display: none;
  background: #1a1a1a;
  padding: 8px 15px;
  border-bottom: 1px solid #222;
}
.xt-mobile-search input {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid #333;
  border-radius: 8px;
  background: #0d0d0d;
  color: #fff;
  font-size: 14px;
  outline: none;
}
.xt-mobile-search input::placeholder { color: #666; }

@media (max-width: 999px) {
  .xt-top-bar, .xt-main-header, .xt-bottom-nav { display: none !important; }
  .xt-mobile-header { display: flex; }
  .xt-mobile-search { display: block; }
}
@media (min-width: 1000px) {
  .xt-mobile-header, .xt-mobile-search { display: none !important; }
}
{%- endstyle -%}

<div class="xtore-header" data-section-id="{{ section.id }}">
  
  <!-- DESKTOP -->
  
  <!-- Top Utility Bar -->
  <div class="xt-top-bar">
    <div class="page-width">
      <div class="xt-top-right">
        <a href="/account/login" class="xt-top-link">
          <span class="xt-top-link-sub">Hello, Sign in</span>
