<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:700;font-size:22px;"><i class="fas fa-box" style="color:var(--gold);margin-right:10px;"></i><%= product.title %></h2>
    <div style="display:flex;gap:8px;">
        <a href="/products/<%= product.id %>/edit" class="btn-3d" style="text-decoration:none;"><i class="fas fa-edit"></i> Edit</a>
        <a href="/products" style="background:var(--dark-card);border:1px solid var(--border);border-radius:12px;padding:12px 20px;font-size:13px;font-weight:600;color:var(--text-dim);text-decoration:none;display:inline-flex;align-items:center;gap:8px;"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card-3d mb-4">
            <div class="card-head"><h6><i class="fas fa-info-circle" style="color:var(--gold);"></i> Product Details</h6></div>
            <div class="card-body-padded">
                <div class="info-row"><span class="info-label">Title</span><span class="info-value"><%= product.title %></span></div>
                <div class="info-row"><span class="info-label">Vendor</span><span class="info-value"><%= product.vendor %></span></div>
                <div class="info-row"><span class="info-label">Product Type</span><span class="info-value"><%= product.product_type %></span></div>
                <div class="info-row"><span class="info-label">Status</span><span class="info-value">
                    <% if (product.status === 'active') { %>
                        <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:rgba(62,207,142,0.15);color:#3ecf8e;">Active</span>
                    <% } else { %>
                        <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--gold-dim);color:var(--text-dim);"><%= product.status %></span>
                    <% } %>
                </span></div>
                <div class="info-row"><span class="info-label">Created</span><span class="info-value"><%= new Date(product.created_at).toLocaleDateString() %></span></div>
                <div class="info-row"><span class="info-label">Updated</span><span class="info-value"><%= new Date(product.updated_at).toLocaleDateString() %></span></div>
            </div>
        </div>

        <div class="card-3d mb-4">
            <div class="card-head"><h6><i class="fas fa-layer-group" style="color:var(--gold);"></i> Variants</h6></div>
            <div class="card-body-padded" style="overflow-x:auto;">
                <table class="table-3d">
                    <thead><tr><th>Title</th><th>Price</th><th>SKU</th><th>Inventory</th><th>Weight</th></tr></thead>
                    <tbody>
                        <% product.variants.forEach(variant => { %>
                        <tr>
                            <td><%= variant.title %></td>
                            <td><strong>$<%= variant.price %></strong></td>
                            <td style="color:var(--text-dim);"><%= variant.sku || 'N/A' %></td>
                            <td><%= variant.inventory_quantity || 0 %></td>
                            <td><%= variant.weight || 0 %> <%= variant.weight_unit %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-3d">
            <div class="card-head"><h6><i class="fas fa-align-left" style="color:var(--gold);"></i> Description</h6></div>
            <div class="card-body-padded">
                <%- product.body_html || '<p style="color:var(--text-dim);">No description</p>' %>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-3d mb-4">
            <div class="card-head"><h6><i class="fas fa-images" style="color:var(--gold);"></i> Images</h6></div>
            <div class="card-body-padded">
                <% if (product.images && product.images.length > 0) { %>
                    <% product.images.forEach(image => { %>
                        <img src="<%= image.src %>" alt="" style="width:100%;border-radius:10px;margin-bottom:8px;border:1px solid var(--border);">
                    <% }); %>
                <% } else { %>
                    <p style="color:var(--text-dim);text-align:center;padding:20px 0;">No images</p>
                <% } %>
            </div>
        </div>

        <div class="card-3d">
            <div class="card-head"><h6><i class="fas fa-tags" style="color:var(--gold);"></i> Tags</h6></div>
            <div class="card-body-padded">
                <% if (product.tags) { %>
                    <% product.tags.split(', ').forEach(tag => { %>
                        <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--gold-dim);color:var(--gold);display:inline-block;margin:2px;"><%= tag %></span>
                    <% }); %>
                <% } else { %>
                    <p style="color:var(--text-dim);text-align:center;padding:20px 0;">No tags</p>
                <% } %>
            </div>
        </div>
    </div>
</div>
