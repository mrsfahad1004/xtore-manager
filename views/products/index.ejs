<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:700;font-size:22px;"><i class="fas fa-box" style="color:var(--gold);margin-right:10px;"></i>Products</h2>
    <a href="/products/new" class="btn-3d" style="text-decoration:none;">
        <i class="fas fa-plus"></i> Add Product
    </a>
</div>

<div class="card-3d">
    <div class="card-head">
        <h6><i class="fas fa-list" style="color:var(--gold);"></i> All Products</h6>
    </div>
    <div class="card-body-padded" style="overflow-x:auto;">
        <table class="table-3d">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Vendor</th>
                    <th>Type</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(product => { %>
                <tr>
                    <td>
                        <% if (product.images && product.images.length > 0) { %>
                            <img src="<%= product.images[0].src %>" alt="" style="width:44px;height:44px;object-fit:cover;border-radius:10px;border:1px solid var(--border);">
                        <% } else { %>
                            <div style="width:44px;height:44px;border-radius:10px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--text-dim);">
                                <i class="fas fa-image"></i>
                            </div>
                        <% } %>
                    </td>
                    <td><strong><%= product.title %></strong></td>
                    <td style="color:var(--text-dim);"><%= product.vendor %></td>
                    <td style="color:var(--text-dim);"><%= product.product_type %></td>
                    <td><strong>$<%= product.variants[0]?.price || '0.00' %></strong></td>
                    <td>
                        <% if (product.status === 'active') { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:rgba(62,207,142,0.15);color:#3ecf8e;">Active</span>
                        <% } else { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--gold-dim);color:var(--text-dim);"><%= product.status %></span>
                        <% } %>
                    </td>
                    <td>
                        <a href="/products/<%= product.id %>" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;color:var(--text-dim);text-decoration:none;margin-right:4px;transition:all 0.2s;"><i class="fas fa-eye" style="font-size:12px;"></i></a>
                        <a href="/products/<%= product.id %>/edit" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;color:var(--text-dim);text-decoration:none;margin-right:4px;transition:all 0.2s;"><i class="fas fa-edit" style="font-size:12px;"></i></a>
                        <form action="/products/<%= product.id %>?_method=DELETE" method="POST" class="d-inline">
                            <button type="submit" onclick="return confirm('Delete this product?')" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:none;display:inline-flex;align-items:center;justify-content:center;color:var(--red);cursor:pointer;transition:all 0.2s;"><i class="fas fa-trash" style="font-size:12px;"></i></button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
