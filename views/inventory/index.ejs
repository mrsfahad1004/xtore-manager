<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-warehouse me-2"></i>Inventory Management</h2>
        <div>
            <select class="form-select form-select-sm" onchange="window.location.href='?location='+this.value" style="width: auto; display: inline-block;">
                <% locations.forEach(location => { %>
                    <option value="<%= location.id %>" <%= selectedLocation == location.id ? 'selected' : '' %>><%= location.name %></option>
                <% }); %>
            </select>
        </div>
    </div>
    
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>SKU</th>
                            <th>Available</th>
                            <th>Adjust</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% inventory.forEach(item => { %>
                        <tr>
                            <td><strong><%= item.inventory_item_id %></strong></td>
                            <td><%= item.sku || 'N/A' %></td>
                            <td>
                                <span class="badge bg-<%= item.available > 0 ? 'success' : 'danger' %>">
                                    <%= item.available || 0 %>
                                </span>
                            </td>
                            <td>
                                <form action="/inventory/adjust" method="POST" class="d-inline">
                                    <input type="hidden" name="inventory_item_id" value="<%= item.inventory_item_id %>">
                                    <input type="hidden" name="location_id" value="<%= selectedLocation %>">
                                    <div class="input-group input-group-sm" style="width: 200px;">
                                        <input type="number" class="form-control" name="available" value="<%= item.available || 0 %>" required>
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fas fa-save"></i>
                                        </button>
                                    </div>
                                </form>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-info" onclick="showItemDetails(<%= item.inventory_item_id %>)">
                                    <i class="fas fa-info-circle"></i>
                                </button>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            
            <% if (inventory.length === 0) { %>
                <div class="text-center py-4">
                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No inventory items found</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
function showItemDetails(itemId) {
    alert('Inventory Item ID: ' + itemId + '\n\nUse the Shopify Admin to view full item details.');
}
</script>