<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:700;font-size:22px;"><i class="fas fa-shopping-bag" style="color:var(--gold);margin-right:10px;"></i>Orders</h2>
    <select onchange="window.location.href='?status='+this.value" style="background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:8px 14px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;cursor:pointer;">
        <option value="any" <%= status === 'any' ? 'selected' : '' %>>All Orders</option>
        <option value="open" <%= status === 'open' ? 'selected' : '' %>>Open</option>
        <option value="closed" <%= status === 'closed' ? 'selected' : '' %>>Closed</option>
        <option value="cancelled" <%= status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
    </select>
</div>

<div class="card-3d">
    <div class="card-head">
        <h6><i class="fas fa-receipt" style="color:var(--gold);"></i> All Orders</h6>
    </div>
    <div class="card-body-padded" style="overflow-x:auto;">
        <table class="table-3d">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Total</th>
                    <th>Payment</th>
                    <th>Fulfillment</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% orders.forEach(order => { %>
                <tr>
                    <td><strong>#<%= order.order_number %></strong></td>
                    <td style="color:var(--text-dim);"><%= new Date(order.created_at).toLocaleDateString() %></td>
                    <td><%= order.customer ? `${order.customer.first_name} ${order.customer.last_name}` : 'Guest' %></td>
                    <td><strong>$<%= order.total_price %></strong></td>
                    <td>
                        <% if (order.financial_status === 'paid') { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:rgba(62,207,142,0.15);color:#3ecf8e;">Paid</span>
                        <% } else if (order.financial_status === 'pending') { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:rgba(245,185,4,0.15);color:var(--gold);">Pending</span>
                        <% } else if (order.financial_status === 'refunded') { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:rgba(215,74,93,0.15);color:var(--red);">Refunded</span>
                        <% } else { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--gold-dim);color:var(--text-dim);"><%= order.financial_status %></span>
                        <% } %>
                    </td>
                    <td>
                        <% if (order.fulfillment_status === 'fulfilled') { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:rgba(62,207,142,0.15);color:#3ecf8e;">Fulfilled</span>
                        <% } else if (order.fulfillment_status === 'partial') { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:rgba(245,185,4,0.15);color:var(--gold);">Partial</span>
                        <% } else { %>
                            <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--gold-dim);color:var(--text-dim);">Unfulfilled</span>
                        <% } %>
                    </td>
                    <td>
                        <a href="/orders/<%= order.id %>" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;color:var(--text-dim);text-decoration:none;transition:all 0.2s;"><i class="fas fa-eye" style="font-size:12px;"></i></a>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
