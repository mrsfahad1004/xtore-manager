<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xtore Manager</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #F5B904;
            --gold-dim: rgba(245,185,4,0.15);
            --gold-glow: rgba(245,185,4,0.3);
            --dark: #060000;
            --dark-2: #0a0a0a;
            --dark-3: #111111;
            --dark-card: rgba(245,185,4,0.03);
            --orange: #FF5B03;
            --red: #d74a5d;
            --text: #F5B904;
            --text-dim: rgba(245,185,4,0.5);
            --border: rgba(245,185,4,0.12);
            --glass: rgba(6,0,0,0.7);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--dark);
            color: var(--text);
            overflow-x: hidden;
            perspective: 1200px;
        }

        /* Animated Background */
        .bg-animation {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none;
        }
        .bg-animation .orb {
            position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.08; animation: orbFloat 20s ease-in-out infinite;
        }
        .bg-animation .orb:nth-child(1) { width: 600px; height: 600px; background: var(--gold); top: -200px; right: -200px; animation-delay: 0s; }
        .bg-animation .orb:nth-child(2) { width: 400px; height: 400px; background: var(--orange); bottom: -100px; left: -100px; animation-delay: -7s; }
        .bg-animation .orb:nth-child(3) { width: 300px; height: 300px; background: var(--gold); top: 50%; left: 50%; animation-delay: -14s; }
        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(50px, -30px) scale(1.1); }
            50% { transform: translate(-20px, 40px) scale(0.95); }
            75% { transform: translate(30px, 20px) scale(1.05); }
        }

        /* Grid Lines Background */
        .grid-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none;
            background-image:
                linear-gradient(rgba(245,185,4,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(245,185,4,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
        }

        /* Layout */
        .app-layout { display: flex; min-height: 100vh; position: relative; z-index: 1; }

        /* 3D Sidebar */
        .sidebar {
            width: 260px; background: var(--glass); backdrop-filter: blur(30px);
            border-right: 1px solid var(--border); position: fixed; top: 0; left: 0; height: 100vh; z-index: 100;
            transform-style: preserve-3d; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .sidebar::before {
            content: ''; position: absolute; top: 0; right: 0; width: 1px; height: 100%;
            background: linear-gradient(180deg, transparent, var(--gold-glow), transparent);
        }
        .sidebar-brand {
            padding: 24px; border-bottom: 1px solid var(--border); position: relative;
        }
        .sidebar-brand::after {
            content: ''; position: absolute; bottom: 0; left: 24px; right: 24px; height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }
        .sidebar-brand .logo {
            display: flex; align-items: center; gap: 12px;
        }
        .sidebar-brand .logo-icon {
            width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--gold), var(--orange)); font-size: 18px; color: var(--dark);
            box-shadow: 0 4px 20px rgba(245,185,4,0.3); transform: rotateY(-5deg) rotateX(5deg);
            transition: transform 0.3s;
        }
        .sidebar-brand:hover .logo-icon { transform: rotateY(0) rotateX(0) scale(1.1); }
        .sidebar-brand h5 { font-size: 18px; font-weight: 700; letter-spacing: 1px; margin: 0; }
        .sidebar-brand small { color: var(--text-dim); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; }
        .sidebar-section { padding: 20px 24px 8px; font-size: 10px; text-transform: uppercase; letter-spacing: 2px; color: var(--text-dim); font-weight: 600; }
        .sidebar-link {
            display: flex; align-items: center; gap: 12px; padding: 11px 24px; color: var(--text-dim);
            text-decoration: none; font-size: 13px; font-weight: 500; transition: all 0.2s;
            border-left: 2px solid transparent; position: relative; overflow: hidden;
        }
        .sidebar-link::before {
            content: ''; position: absolute; left: 0; top: 0; width: 0; height: 100%;
            background: linear-gradient(90deg, var(--gold-dim), transparent); transition: width 0.3s;
        }
        .sidebar-link:hover { color: var(--gold); }
        .sidebar-link:hover::before { width: 100%; }
        .sidebar-link.active { color: var(--gold); border-left-color: var(--gold); background: var(--gold-dim); }
        .sidebar-link i { width: 18px; text-align: center; font-size: 14px; position: relative; z-index: 1; }
        .sidebar-link span { position: relative; z-index: 1; }
        .sidebar-link .badge-new {
            font-size: 9px; padding: 2px 7px; border-radius: 8px; margin-left: auto;
            background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--dark);
            font-weight: 700; letter-spacing: 0.5px; position: relative; z-index: 1;
        }

        /* Main */
        .main-area { margin-left: 260px; flex: 1; position: relative; }

        /* 3D Topbar */
        .topbar {
            height: 60px; background: var(--glass); backdrop-filter: blur(30px);
            border-bottom: 1px solid var(--border); display: flex; align-items: center;
            justify-content: space-between; padding: 0 32px; position: sticky; top: 0; z-index: 50;
        }
        .topbar::after {
            content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold-glow), transparent);
        }
        .topbar h1 { font-size: 18px; font-weight: 600; letter-spacing: 0.5px; }
        .topbar-right { display: flex; align-items: center; gap: 16px; }
        .status-dot { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-dim); }
        .status-dot::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: #3ecf8e; box-shadow: 0 0 8px rgba(62,207,142,0.6); animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { box-shadow: 0 0 8px rgba(62,207,142,0.6); } 50% { box-shadow: 0 0 16px rgba(62,207,142,0.9); } }

        /* Content */
        .content { padding: 28px 32px; }

        /* 3D Stat Cards */
        .stat-card {
            background: var(--dark-card); backdrop-filter: blur(20px);
            border: 1px solid var(--border); border-radius: 16px; padding: 24px;
            position: relative; overflow: hidden;
            transform: perspective(800px) rotateX(2deg) rotateY(-1deg);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            transform-style: preserve-3d;
        }
        .stat-card:hover {
            transform: perspective(800px) rotateX(0) rotateY(0) translateY(-8px) scale(1.02);
            box-shadow: 0 20px 60px rgba(245,185,4,0.1), 0 0 40px rgba(245,185,4,0.05);
            border-color: var(--gold-glow);
        }
        .stat-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent); opacity: 0;
            transition: opacity 0.3s;
        }
        .stat-card:hover::before { opacity: 1; }
        .stat-card .glow {
            position: absolute; top: -30px; right: -30px; width: 100px; height: 100px;
            border-radius: 50%; filter: blur(40px); opacity: 0.15; transition: opacity 0.3s;
        }
        .stat-card:hover .glow { opacity: 0.25; }
        .stat-card p { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-dim); font-weight: 600; margin: 0; }
        .stat-card h2 { font-size: 36px; font-weight: 700; margin: 8px 0 0; background: linear-gradient(135deg, var(--gold), #fff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .stat-card .stat-icon-3d {
            position: absolute; top: 18px; right: 18px; width: 44px; height: 44px;
            border-radius: 12px; display: flex; align-items: center; justify-content: center;
            font-size: 18px; color: var(--dark);
            transform: translateZ(20px) rotateY(-10deg);
            transition: transform 0.3s;
            box-shadow: 0 4px 20px rgba(245,185,4,0.2);
        }
        .stat-card:hover .stat-icon-3d { transform: translateZ(30px) rotateY(0) scale(1.1); }

        /* 3D Action Cards */
        .action-3d {
            background: var(--dark-card); backdrop-filter: blur(20px);
            border: 1px solid var(--border); border-radius: 16px; padding: 28px 20px;
            text-align: center; cursor: pointer; text-decoration: none; color: inherit;
            transform: perspective(600px) rotateX(3deg);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative; overflow: hidden;
        }
        .action-3d::before {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, var(--gold-glow) 0%, transparent 70%);
            opacity: 0; transition: opacity 0.4s;
        }
        .action-3d:hover::before { opacity: 0.08; }
        .action-3d:hover {
            transform: perspective(600px) rotateX(0) translateY(-10px) scale(1.03);
            border-color: var(--gold-glow);
            box-shadow: 0 20px 50px rgba(245,185,4,0.08);
        }
        .action-3d .icon-3d {
            width: 56px; height: 56px; border-radius: 16px; display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px; font-size: 22px; color: var(--dark); position: relative; z-index: 1;
            box-shadow: 0 8px 30px rgba(245,185,4,0.25);
            transform: translateZ(15px);
            transition: transform 0.3s;
        }
        .action-3d:hover .icon-3d { transform: translateZ(25px) scale(1.1); }
        .action-3d h6 { font-size: 14px; font-weight: 600; margin: 0; position: relative; z-index: 1; }
        .action-3d small { font-size: 11px; color: var(--text-dim); position: relative; z-index: 1; }

        /* 3D Cards */
        .card-3d {
            background: var(--dark-card); backdrop-filter: blur(20px);
            border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
            transform: perspective(800px) rotateX(1deg);
            transition: all 0.3s;
        }
        .card-3d:hover { transform: perspective(800px) rotateX(0); border-color: var(--gold-glow); }
        .card-3d .card-head {
            padding: 18px 22px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
        }
        .card-3d .card-head h6 { margin: 0; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
        .card-3d .card-body-padded { padding: 20px 22px; }

        /* Table */
        .table-3d { width: 100%; border-collapse: collapse; }
        .table-3d th { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-dim); font-weight: 600; padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border); }
        .table-3d td { padding: 12px 14px; font-size: 13px; border-bottom: 1px solid rgba(245,185,4,0.05); }
        .table-3d tr { transition: background 0.15s; }
        .table-3d tr:hover td { background: var(--gold-dim); }

        /* Info rows */
        .info-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid rgba(245,185,4,0.05); }
        .info-row:last-child { border-bottom: none; }
        .info-label { font-size: 12px; color: var(--text-dim); }
        .info-value { font-size: 13px; font-weight: 600; }

        /* Buttons */
        .btn-3d {
            background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--dark);
            border: none; border-radius: 12px; padding: 12px 24px; font-size: 13px; font-weight: 700;
            cursor: pointer; display: inline-flex; align-items: center; gap: 8px; letter-spacing: 0.5px;
            box-shadow: 0 4px 20px rgba(245,185,4,0.3);
            transform: perspective(400px) rotateX(5deg);
            transition: all 0.3s;
        }
        .btn-3d:hover {
            transform: perspective(400px) rotateX(0) translateY(-3px);
            box-shadow: 0 8px 30px rgba(245,185,4,0.4);
        }

        /* ========== 3D CHATBOX ========== */
        #ai-chatbox { position: fixed; bottom: 24px; right: 24px; z-index: 99999; }
        #chat-toggle {
            width: 60px; height: 60px; border-radius: 18px;
            background: linear-gradient(135deg, var(--gold), var(--orange));
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--dark); font-size: 24px;
            box-shadow: 0 8px 32px rgba(245,185,4,0.4);
            transform: perspective(400px) rotateY(-8deg) rotateX(5deg);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
        }
        #chat-toggle::before {
            content: ''; position: absolute; inset: -3px; border-radius: 21px;
            background: linear-gradient(135deg, var(--gold), var(--orange)); z-index: -1;
            opacity: 0.3; filter: blur(10px); animation: toggleGlow 3s ease-in-out infinite;
        }
        @keyframes toggleGlow { 0%, 100% { opacity: 0.3; } 50% { opacity: 0.5; } }
        #chat-toggle:hover {
            transform: perspective(400px) rotateY(0) rotateX(0) scale(1.1);
            box-shadow: 0 12px 40px rgba(245,185,4,0.5);
        }
        #chat-window {
            position: absolute; bottom: 72px; right: 0; width: 420px; height: 600px;
            background: var(--glass); backdrop-filter: blur(40px);
            border: 1px solid var(--border); border-radius: 20px;
            box-shadow: 0 24px 80px rgba(0,0,0,0.5), 0 0 60px rgba(245,185,4,0.05);
            display: flex; flex-direction: column; overflow: hidden;
            transform: perspective(800px) rotateY(-5deg) rotateX(3deg) scale(0.9);
            transform-origin: bottom right;
            animation: chatOpen 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes chatOpen {
            from { transform: perspective(800px) rotateY(-15deg) rotateX(8deg) scale(0.7); opacity: 0; }
            to { transform: perspective(800px) rotateY(0) rotateX(0) scale(1); opacity: 1; }
        }
        #chat-window.hidden { display: none; }
        #chat-header {
            padding: 16px 20px; border-bottom: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: center;
            background: rgba(245,185,4,0.03);
        }
        #chat-header .ch-left { display: flex; align-items: center; gap: 10px; }
        #chat-header .ch-icon {
            width: 38px; height: 38px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--dark); font-size: 16px;
            box-shadow: 0 4px 15px rgba(245,185,4,0.3);
        }
        #chat-header strong { font-size: 14px; }
        #chat-header small { display: block; font-size: 10px; color: var(--text-dim); display: flex; align-items: center; gap: 4px; }
        #chat-header small::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #3ecf8e; }
        #chat-header .ch-btns { display: flex; gap: 4px; }
        #chat-header .ch-btns button { background: none; border: 1px solid var(--border); color: var(--text-dim); width: 30px; height: 30px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 12px; transition: all 0.2s; }
        #chat-header .ch-btns button:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); }

        #chat-messages { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
        #chat-messages::-webkit-scrollbar { width: 3px; }
        #chat-messages::-webkit-scrollbar-thumb { background: var(--gold-dim); border-radius: 3px; }

        .msg { display: flex; gap: 8px; max-width: 88%; animation: msgIn 0.3s ease; }
        @keyframes msgIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
        .bot-msg { align-self: flex-start; }
        .user-msg { align-self: flex-end; flex-direction: row-reverse; }
        .msg-avatar { width: 28px; height: 28px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 11px; }
        .bot-msg .msg-avatar { background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--dark); }
        .user-msg .msg-avatar { background: var(--dark-3); color: var(--gold); border: 1px solid var(--border); }
        .msg-body { padding: 10px 14px; border-radius: 12px; font-size: 13px; line-height: 1.55; word-break: break-word; }
        .bot-msg .msg-body { background: var(--dark-card); border: 1px solid var(--border); color: var(--text); }
        .user-msg .msg-body { background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--dark); font-weight: 500; }
        .msg-body strong { color: var(--gold); }
        .user-msg .msg-body strong { color: var(--dark); }
        .msg-body code { background: rgba(245,185,4,0.1); padding: 1px 5px; border-radius: 4px; font-size: 11px; color: var(--gold); }
        .msg-body em { color: var(--text-dim); font-size: 11px; }

        .tool-exec { background: var(--gold-dim); border-left: 3px solid var(--gold); border-radius: 0 10px 10px 0; padding: 12px 14px; margin: 6px 0; font-size: 12px; }
        .tool-exec-header { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; font-weight: 700; color: var(--gold); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }
        .tool-exec table { width: 100%; font-size: 11px; border-collapse: collapse; }
        .tool-exec th { text-align: left; padding: 6px 10px; background: rgba(245,185,4,0.08); font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-dim); border-radius: 4px; }
        .tool-exec td { padding: 6px 10px; border-bottom: 1px solid rgba(245,185,4,0.06); }
        .tool-success { background: rgba(62,207,142,0.08); border-left: 3px solid #3ecf8e; padding: 12px 14px; border-radius: 0 10px 10px 0; margin: 6px 0; font-size: 12px; color: #3ecf8e; }
        .tool-error { background: rgba(215,74,93,0.08); border-left: 3px solid var(--red); padding: 12px 14px; border-radius: 0 10px 10px 0; margin: 6px 0; font-size: 12px; color: var(--red); }
        .tool-detail { background: var(--dark-card); border: 1px solid var(--border); border-radius: 10px; padding: 12px 14px; margin: 6px 0; font-size: 12px; }
        .tool-detail-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid rgba(245,185,4,0.05); }
        .tool-detail-row:last-child { border-bottom: none; }
        .tool-detail-label { color: var(--text-dim); font-size: 11px; }
        .tool-detail-value { font-weight: 600; font-size: 12px; }
        .tool-code { background: var(--dark); border: 1px solid var(--border); color: var(--gold); padding: 12px; border-radius: 10px; font-family: 'Fira Code', monospace; font-size: 11px; white-space: pre-wrap; max-height: 180px; overflow-y: auto; margin: 6px 0; }

        #chat-tools-panel { border-top: 1px solid var(--border); padding: 10px; max-height: 170px; overflow-y: auto; background: rgba(245,185,4,0.02); }
        #chat-tools-panel.hidden { display: none; }
        .tools-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
        .tool-card { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 8px 4px; border-radius: 10px; cursor: pointer; transition: all 0.2s; border: 1px solid transparent; text-align: center; }
        .tool-card:hover { background: var(--gold-dim); border-color: var(--gold); transform: translateY(-2px); }
        .tool-card i { font-size: 13px; padding: 6px; border-radius: 8px; color: #fff; }
        .tool-card span { font-size: 9px; color: var(--text); font-weight: 600; letter-spacing: 0.3px; }

        .typing { display: flex; gap: 4px; padding: 8px 12px; background: var(--dark-card); border: 1px solid var(--border); border-radius: 10px; width: fit-content; }
        .typing span { width: 5px; height: 5px; background: var(--gold); border-radius: 50%; animation: bounce 1.4s infinite; opacity: 0.4; }
        .typing span:nth-child(2) { animation-delay: 0.2s; }
        .typing span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes bounce { 0%, 60%, 100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-5px); opacity: 1; } }

        #quick-actions { display: flex; gap: 4px; padding: 8px 12px 4px; }
        #quick-actions button {
            width: 34px; height: 34px; border-radius: 10px; border: 1px solid var(--border);
            background: var(--dark-card); display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 12px; color: var(--text-dim); transition: all 0.2s;
        }
        #quick-actions button:hover { background: var(--gold); color: var(--dark); border-color: var(--gold); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(245,185,4,0.2); }

        #chat-input-area { padding: 8px 12px 12px; border-top: 1px solid var(--border); }
        #chat-input-area .input-group { display: flex; gap: 6px; }
        #chat-input {
            flex: 1; background: var(--dark-card); border: 1px solid var(--border); border-radius: 12px;
            padding: 11px 16px; font-size: 13px; color: var(--text); outline: none;
            font-family: 'Space Grotesk', sans-serif; transition: border-color 0.2s;
        }
        #chat-input::placeholder { color: var(--text-dim); }
        #chat-input:focus { border-color: var(--gold); box-shadow: 0 0 20px rgba(245,185,4,0.1); }
        #send-btn {
            background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--dark);
            border: none; border-radius: 12px; width: 42px; height: 42px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; font-size: 14px; flex-shrink: 0;
            box-shadow: 0 4px 15px rgba(245,185,4,0.3);
            transition: all 0.2s;
        }
        #send-btn:hover { transform: scale(1.08); box-shadow: 0 6px 20px rgba(245,185,4,0.4); }

        @media (max-width: 768px) {
            .sidebar { display: none; }
            .main-area { margin-left: 0; }
            #chat-window { width: calc(100vw - 24px); height: 75vh; right: -8px; }
        }
    </style>
</head>
<body>
    <div class="bg-animation">
        <div class="orb"></div>
        <div class="orb"></div>
        <div class="orb"></div>
    </div>
    <div class="grid-bg"></div>

    <div class="app-layout">
        <div class="sidebar">
            <div class="sidebar-brand">
                <div class="logo">
                    <div class="logo-icon"><i class="fas fa-bolt"></i></div>
                    <div>
                        <h5>XTORE</h5>
                        <small>AI Manager</small>
                    </div>
                </div>
            </div>
            <div class="sidebar-section">Navigation</div>
            <a class="sidebar-link" href="/" data-page="/"><i class="fas fa-th-large"></i><span>Dashboard</span></a>
            <div class="sidebar-section">Store</div>
            <a class="sidebar-link" href="/products" data-page="/products"><i class="fas fa-cube"></i><span>Products</span></a>
            <a class="sidebar-link" href="/orders" data-page="/orders"><i class="fas fa-shopping-bag"></i><span>Orders</span></a>
            <a class="sidebar-link" href="/customers" data-page="/customers"><i class="fas fa-users"></i><span>Customers</span></a>
            <a class="sidebar-link" href="/inventory" data-page="/inventory"><i class="fas fa-warehouse"></i><span>Inventory</span></a>
            <div class="sidebar-section">Intelligence</div>
            <a class="sidebar-link" href="#" onclick="toggleChat();return false;">
                <i class="fas fa-robot"></i><span>AI Agent</span>
                <span class="badge-new">AI</span>
            </a>
            <div class="sidebar-section">Account</div>
            <a class="sidebar-link" href="/auth/logout"><i class="fas fa-sign-out-alt"></i><span>Disconnect</span></a>
        </div>

        <div class="main-area">
            <div class="topbar">
                <h1 id="page-title">Dashboard</h1>
                <div class="topbar-right">
                    <span class="status-dot" id="store-label">Connected</span>
                </div>
            </div>
            <div class="content"><%- body %></div>
        </div>
    </div>

    <%- include('chatbox') %>

    <script>
        const path = window.location.pathname;
        document.querySelectorAll('.sidebar-link[data-page]').forEach(a => {
            if (path === a.dataset.page || (path === '/' && a.dataset.page === '/')) a.classList.add('active');
        });
        const titles = {'/':'Dashboard','/products':'Products','/orders':'Orders','/customers':'Customers','/inventory':'Inventory'};
        document.getElementById('page-title').textContent = titles[path] || 'Xtore Manager';
    </script>
</body>
</html>
