<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon-3d" style="background:linear-gradient(135deg,var(--gold),var(--orange));">
                <i class="fas fa-box"></i>
            </div>
            <div class="glow" style="background:var(--gold);"></div>
            <p>Products</p>
            <h2><%= stats.productsCount %></h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="transform:perspective(800px) rotateX(2deg) rotateY(1deg);">
            <div class="stat-icon-3d" style="background:linear-gradient(135deg,var(--orange),var(--gold));">
                <i class="fas fa-shopping-bag"></i>
            </div>
            <div class="glow" style="background:var(--orange);"></div>
            <p>Orders</p>
            <h2><%= stats.ordersCount %></h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="transform:perspective(800px) rotateX(2deg) rotateY(-1deg);">
            <div class="stat-icon-3d" style="background:linear-gradient(135deg,#3ecf8e,var(--gold));">
                <i class="fas fa-users"></i>
            </div>
            <div class="glow" style="background:#3ecf8e;"></div>
            <p>Customers</p>
            <h2><%= stats.customersCount %></h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="transform:perspective(800px) rotateX(2deg) rotateY(1deg);">
            <div class="stat-icon-3d" style="background:linear-gradient(135deg,var(--gold),#fff);">
                <i class="fas fa-store"></i>
            </div>
            <div class="glow" style="background:var(--gold);"></div>
            <p>Store</p>
            <h2 style="font-size:16px;margin-top:8px;"><%= stats.shop?.name || 'N/A' %></h2>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <a href="/products/new" class="action-3d d-block">
            <div class="icon-3d" style="background:linear-gradient(135deg,var(--gold),var(--orange));"><i class="fas fa-plus"></i></div>
            <h6>Add Product</h6>
            <small>Create new item</small>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/orders" class="action-3d d-block">
            <div class="icon-3d" style="background:linear-gradient(135deg,var(--orange),var(--gold));"><i class="fas fa-shopping-bag"></i></div>
            <h6>View Orders</h6>
            <small>Manage orders</small>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/inventory" class="action-3d d-block">
            <div class="icon-3d" style="background:linear-gradient(135deg,#3ecf8e,var(--gold));"><i class="fas fa-warehouse"></i></div>
            <h6>Inventory</h6>
            <small>Check stock levels</small>
        </a>
    </div>
    <div class="col-md-3">
        <a href="/customers" class="action-3d d-block">
            <div class="icon-3d" style="background:linear-gradient(135deg,var(--gold),#3ecf8e);"><i class="fas fa-user-plus"></i></div>
            <h6>Add Customer</h6>
            <small>New customer</small>
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card-3d">
            <div class="card-head">
                <h6><i class="fas fa-store" style="color:var(--gold);"></i> Store Information</h6>
            </div>
            <div class="card-body-padded">
                <div class="info-row"><span class="info-label">Store Name</span><span class="info-value"><%= stats.shop?.name || 'N/A' %></span></div>
                <div class="info-row"><span class="info-label">Domain</span><span class="info-value"><%= stats.shop?.domain || 'N/A' %></span></div>
                <div class="info-row"><span class="info-label">Email</span><span class="info-value"><%= stats.shop?.email || 'N/A' %></span></div>
                <div class="info-row"><span class="info-label">Currency</span><span class="info-value"><%= stats.shop?.currency || 'N/A' %></span></div>
                <div class="info-row"><span class="info-label">Plan</span><span class="info-value"><%= stats.shop?.plan_name || 'N/A' %></span></div>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card-3d">
            <div class="card-head">
                <h6><i class="fas fa-robot" style="color:var(--gold);"></i> AI Assistant</h6>
            </div>
            <div class="card-body-padded text-center py-4">
                <div style="width:64px;height:64px;background:linear-gradient(135deg,var(--gold),var(--orange));border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 8px 30px rgba(245,185,4,0.25);">
                    <i class="fas fa-robot fa-2x" style="color:var(--dark);"></i>
                </div>
                <h6 style="font-size:15px;margin-bottom:4px;">Xtore AI Agent</h6>
                <p style="color:var(--text-dim);font-size:13px;margin-bottom:16px;">Products, orders, customers, inventory - sab manage karo chat se</p>
                <button onclick="toggleChat()" class="btn-3d">
                    <i class="fas fa-comment-dots"></i> Open AI Chat
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('store-label').textContent = '<%= stats.shop?.name || "Connected" %>';
</script>
