<div class="container-fluid p-0">
    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#667eea,#764ba2);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p>Products</p>
                        <h3><%= stats.productsCount %></h3>
                    </div>
                    <i class="fas fa-box fa-2x" style="opacity:0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#f093fb,#f5576c);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p>Orders</p>
                        <h3><%= stats.ordersCount %></h3>
                    </div>
                    <i class="fas fa-shopping-cart fa-2x" style="opacity:0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#4facfe,#00f2fe);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p>Customers</p>
                        <h3><%= stats.customersCount %></h3>
                    </div>
                    <i class="fas fa-users fa-2x" style="opacity:0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#43e97b,#38f9d7);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p>Store</p>
                        <h3 style="font-size:18px;"><%= stats.shop?.name || 'N/A' %></h3>
                    </div>
                    <i class="fas fa-store fa-2x" style="opacity:0.3;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Quick Actions -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header"><strong>Quick Actions</strong></div>
                <div class="card-body">
                    <a href="/products/new" class="btn btn-primary w-100 mb-2"><i class="fas fa-plus me-1"></i> Add Product</a>
                    <a href="/customers/new" class="btn btn-success w-100 mb-2"><i class="fas fa-user-plus me-1"></i> Add Customer</a>
                    <a href="/inventory" class="btn btn-warning w-100 mb-2"><i class="fas fa-boxes me-1"></i> Inventory</a>
                    <a href="/orders" class="btn btn-info w-100"><i class="fas fa-eye me-1"></i> View Orders</a>
                </div>
            </div>
        </div>

        <!-- Store Info -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header"><strong>Store Info</strong></div>
                <div class="card-body p-0">
                    <table class="table table-borderless mb-0">
                        <tr><td class="text-muted" style="font-size:12px;">Name</td><td style="font-size:13px;"><strong><%= stats.shop?.name || 'N/A' %></strong></td></tr>
                        <tr><td class="text-muted" style="font-size:12px;">Domain</td><td style="font-size:13px;"><%= stats.shop?.domain || 'N/A' %></td></tr>
                        <tr><td class="text-muted" style="font-size:12px;">Email</td><td style="font-size:13px;"><%= stats.shop?.email || 'N/A' %></td></tr>
                        <tr><td class="text-muted" style="font-size:12px;">Currency</td><td style="font-size:13px;"><%= stats.shop?.currency || 'N/A' %></td></tr>
                        <tr><td class="text-muted" style="font-size:12px;">Plan</td><td style="font-size:13px;"><%= stats.shop?.plan_name || 'N/A' %></td></tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- AI Agent -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header"><strong><i class="fas fa-robot me-1"></i> AI Agent</strong></div>
                <div class="card-body text-center py-4">
                    <i class="fas fa-robot fa-3x mb-3" style="color:#667eea;"></i>
                    <h6>Store ke baare mein kuch bhi poochho</h6>
                    <p style="font-size:12px;color:#888;">Products, orders, customers - sab manage karo chat se</p>
                    <button onclick="toggleChat()" class="btn btn-sm" style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;">
                        <i class="fas fa-comment me-1"></i> Open AI Chat
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('store-name').textContent = '<%= stats.shop?.name || "" %>';
</script>
