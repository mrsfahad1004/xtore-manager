<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:700;font-size:22px;"><i class="fas fa-users" style="color:var(--gold);margin-right:10px;"></i>Customers</h2>
    <a href="/customers/new" class="btn-3d" style="text-decoration:none;">
        <i class="fas fa-plus"></i> Add Customer
    </a>
</div>

<div class="card-3d">
    <div class="card-head">
        <h6><i class="fas fa-address-book" style="color:var(--gold);"></i> All Customers</h6>
    </div>
    <div class="card-body-padded" style="overflow-x:auto;">
        <table class="table-3d">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Orders</th>
                    <th>Total Spent</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% customers.forEach(customer => { %>
                <tr>
                    <td><strong><%= customer.first_name %> <%= customer.last_name %></strong></td>
                    <td style="color:var(--text-dim);"><%= customer.email %></td>
                    <td style="color:var(--text-dim);"><%= customer.phone || 'N/A' %></td>
                    <td><%= customer.orders_count || 0 %></td>
                    <td><strong>$<%= customer.total_spent || '0.00' %></strong></td>
                    <td>
                        <a href="/customers/<%= customer.id %>" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;color:var(--text-dim);text-decoration:none;margin-right:4px;transition:all 0.2s;"><i class="fas fa-eye" style="font-size:12px;"></i></a>
                        <a href="/customers/<%= customer.id %>/edit" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;color:var(--text-dim);text-decoration:none;transition:all 0.2s;"><i class="fas fa-edit" style="font-size:12px;"></i></a>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
