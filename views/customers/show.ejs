<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-user me-2"></i><%= customer.first_name %> <%= customer.last_name %></h2>
        <div>
            <a href="/customers/<%= customer.id %>/edit" class="btn btn-warning">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <a href="/customers" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back
            </a>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-8">
            <!-- Customer Details -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Customer Details</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <td class="text-muted" style="width: 200px;">Name:</td>
                            <td><strong><%= customer.first_name %> <%= customer.last_name %></strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Email:</td>
                            <td><%= customer.email %></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Phone:</td>
                            <td><%= customer.phone || 'N/A' %></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Orders Count:</td>
                            <td><%= customer.orders_count || 0 %></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Total Spent:</td>
                            <td><strong>$<%= customer.total_spent || '0.00' %></strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Created:</td>
                            <td><%= new Date(customer.created_at).toLocaleDateString() %></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Updated:</td>
                            <td><%= new Date(customer.updated_at).toLocaleDateString() %></td>
                        </tr>
                    </table>
                </div>
            </div>
            
            <!-- Addresses -->
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Addresses</h5>
                </div>
                <div class="card-body">
                    <% if (customer.addresses && customer.addresses.length > 0) { %>
                        <% customer.addresses.forEach(address => { %>
                            <div class="card mb-2">
                                <div class="card-body">
                                    <p class="mb-1"><%= address.name %></p>
                                    <p class="mb-1"><%= address.address1 %></p>
                                    <% if (address.address2) { %>
                                        <p class="mb-1"><%= address.address2 %></p>
                                    <% } %>
                                    <p class="mb-1"><%= address.city %>, <%= address.province %> <%= address.zip %></p>
                                    <p class="mb-0"><%= address.country %></p>
                                    <% if (address.default) { %>
                                        <span class="badge bg-primary mt-2">Default</span>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-muted">No addresses</p>
                    <% } %>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <!-- Quick Stats -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Quick Stats</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <h2 class="text-primary"><%= customer.orders_count || 0 %></h2>
                        <p class="text-muted mb-0">Total Orders</p>
                    </div>
                    <hr>
                    <div class="text-center">
                        <h2 class="text-success">$<%= customer.total_spent || '0.00' %></h2>
                        <p class="text-muted mb-0">Total Spent</p>
                    </div>
                </div>
            </div>
            
            <!-- Tags -->
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Tags</h5>
                </div>
                <div class="card-body">
                    <% if (customer.tags) { %>
                        <% customer.tags.split(', ').forEach(tag => { %>
                            <span class="badge bg-primary me-1 mb-1"><%= tag %></span>
                        <% }); %>
                    <% } else { %>
                        <p class="text-muted">No tags</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>