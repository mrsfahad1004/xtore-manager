<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:700;font-size:22px;"><i class="fas fa-user" style="color:var(--gold);margin-right:10px;"></i><%= customer.first_name %> <%= customer.last_name %></h2>
    <div style="display:flex;gap:8px;">
        <a href="/customers/<%= customer.id %>/edit" class="btn-3d" style="text-decoration:none;"><i class="fas fa-edit"></i> Edit</a>
        <a href="/customers" style="background:var(--dark-card);border:1px solid var(--border);border-radius:12px;padding:12px 20px;font-size:13px;font-weight:600;color:var(--text-dim);text-decoration:none;display:inline-flex;align-items:center;gap:8px;"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card-3d mb-4">
            <div class="card-head"><h6><i class="fas fa-id-card" style="color:var(--gold);"></i> Customer Details</h6></div>
            <div class="card-body-padded">
                <div class="info-row"><span class="info-label">Name</span><span class="info-value"><strong><%= customer.first_name %> <%= customer.last_name %></strong></span></div>
                <div class="info-row"><span class="info-label">Email</span><span class="info-value"><%= customer.email %></span></div>
                <div class="info-row"><span class="info-label">Phone</span><span class="info-value"><%= customer.phone || 'N/A' %></span></div>
                <div class="info-row"><span class="info-label">Orders Count</span><span class="info-value"><%= customer.orders_count || 0 %></span></div>
                <div class="info-row"><span class="info-label">Total Spent</span><span class="info-value"><strong>$<%= customer.total_spent || '0.00' %></strong></span></div>
                <div class="info-row"><span class="info-label">Created</span><span class="info-value"><%= new Date(customer.created_at).toLocaleDateString() %></span></div>
                <div class="info-row"><span class="info-label">Updated</span><span class="info-value"><%= new Date(customer.updated_at).toLocaleDateString() %></span></div>
            </div>
        </div>

        <div class="card-3d">
            <div class="card-head"><h6><i class="fas fa-map-marker-alt" style="color:var(--gold);"></i> Addresses</h6></div>
            <div class="card-body-padded">
                <% if (customer.addresses && customer.addresses.length > 0) { %>
                    <% customer.addresses.forEach(address => { %>
                        <div class="card-3d mb-2">
                            <div class="card-body-padded">
                                <div class="info-row"><span class="info-label">Name</span><span class="info-value"><%= address.name %></span></div>
                                <div class="info-row"><span class="info-label">Address</span><span class="info-value"><%= address.address1 %><% if (address.address2) { %><br><%= address.address2 %><% } %></span></div>
                                <div class="info-row"><span class="info-label">City</span><span class="info-value"><%= address.city %>, <%= address.province %> <%= address.zip %></span></div>
                                <div class="info-row"><span class="info-label">Country</span><span class="info-value"><%= address.country %></span></div>
                                <% if (address.default) { %>
                                    <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--gold-dim);color:var(--gold);display:inline-block;margin-top:4px;">Default</span>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color:var(--text-dim);text-align:center;padding:20px 0;">No addresses</p>
                <% } %>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-3d mb-4">
            <div class="card-head"><h6><i class="fas fa-chart-bar" style="color:var(--gold);"></i> Quick Stats</h6></div>
            <div class="card-body-padded text-center">
                <h2 style="font-weight:700;color:var(--gold);"><%= customer.orders_count || 0 %></h2>
                <p style="color:var(--text-dim);font-size:12px;margin-bottom:16px;">Total Orders</p>
                <hr style="border:none;border-top:1px solid var(--border);">
                <h2 style="font-weight:700;color:#3ecf8e;">$<%= customer.total_spent || '0.00' %></h2>
                <p style="color:var(--text-dim);font-size:12px;margin:0;">Total Spent</p>
            </div>
        </div>

        <div class="card-3d">
            <div class="card-head"><h6><i class="fas fa-tags" style="color:var(--gold);"></i> Tags</h6></div>
            <div class="card-body-padded">
                <% if (customer.tags) { %>
                    <% customer.tags.split(', ').forEach(tag => { %>
                        <span style="padding:3px 10px;border-radius:6px;font-size:11px;font-weight:600;background:var(--gold-dim);color:var(--gold);display:inline-block;margin:2px;"><%= tag %></span>
                    <% }); %>
                <% } else { %>
                    <p style="color:var(--text-dim);text-align:center;padding:20px 0;">No tags</p>
                <% } %>
            </div>
        </div>
    </div>
</div>
