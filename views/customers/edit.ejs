<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:700;font-size:22px;"><i class="fas fa-edit" style="color:var(--gold);margin-right:10px;"></i>Edit Customer</h2>
    <a href="/customers/<%= customer.id %>" style="background:var(--dark-card);border:1px solid var(--border);border-radius:12px;padding:12px 20px;font-size:13px;font-weight:600;color:var(--text-dim);text-decoration:none;display:inline-flex;align-items:center;gap:8px;"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="card-3d">
    <div class="card-body-padded">
        <form action="/customers/<%= customer.id %>?_method=PUT" method="POST">
            <div class="row">
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">First Name *</label><input type="text" name="first_name" value="<%= customer.first_name %>" required style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Last Name *</label><input type="text" name="last_name" value="<%= customer.last_name %>" required style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
            </div>
            <div class="row">
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Email *</label><input type="email" name="email" value="<%= customer.email %>" required style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Phone</label><input type="tel" name="phone" value="<%= customer.phone %>" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
            </div>
            <div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Tags (comma separated)</label><input type="text" name="tags" value="<%= customer.tags %>" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div>
            <div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Notes</label><textarea name="note" rows="3" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;resize:vertical;"><%= customer.note %></textarea></div>

            <div style="margin-top:24px;display:flex;gap:10px;">
                <button type="submit" class="btn-3d"><i class="fas fa-save"></i> Update Customer</button>
                <a href="/customers/<%= customer.id %>" style="background:var(--dark-card);border:1px solid var(--border);border-radius:12px;padding:12px 24px;font-size:13px;font-weight:600;color:var(--text-dim);text-decoration:none;">Cancel</a>
            </div>
        </form>
    </div>
</div>
