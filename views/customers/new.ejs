<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-weight:700;font-size:22px;"><i class="fas fa-user-plus" style="color:var(--gold);margin-right:10px;"></i>Add New Customer</h2>
    <a href="/customers" style="background:var(--dark-card);border:1px solid var(--border);border-radius:12px;padding:12px 20px;font-size:13px;font-weight:600;color:var(--text-dim);text-decoration:none;display:inline-flex;align-items:center;gap:8px;"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="card-3d">
    <div class="card-body-padded">
        <form action="/customers" method="POST">
            <div class="row">
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">First Name *</label><input type="text" name="first_name" required style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Last Name *</label><input type="text" name="last_name" required style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
            </div>
            <div class="row">
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Email *</label><input type="email" name="email" required style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">Phone</label><input type="tel" name="phone" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
            </div>
            <div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Tags (comma separated)</label><input type="text" name="tags" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div>
            <div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Notes</label><textarea name="note" rows="3" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;resize:vertical;"></textarea></div>

            <h5 style="font-weight:700;margin:24px 0 16px;color:var(--gold);font-size:15px;"><i class="fas fa-map-marker-alt" style="margin-right:8px;"></i>Address</h5>
            <div class="row">
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Address 1</label><input type="text" name="address1" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
                <div class="col-md-6"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Address 2</label><input type="text" name="address2" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
            </div>
            <div class="row">
                <div class="col-md-4"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">City</label><input type="text" name="city" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
                <div class="col-md-4"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Province/State</label><input type="text" name="province" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
                <div class="col-md-4"><div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Zip/Postal Code</label><input type="text" name="zip" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div></div>
            </div>
            <div style="margin-bottom:18px;"><label style="display:block;font-size:12px;font-weight:600;color:var(--text-dim);margin-bottom:6px;">Country</label><input type="text" name="country" style="width:100%;background:var(--dark-card);border:1px solid var(--border);border-radius:10px;padding:11px 16px;color:var(--text);font-size:13px;font-family:'Space Grotesk',sans-serif;outline:none;"></div>

            <div style="margin-top:24px;display:flex;gap:10px;">
                <button type="submit" class="btn-3d"><i class="fas fa-save"></i> Create Customer</button>
                <a href="/customers" style="background:var(--dark-card);border:1px solid var(--border);border-radius:12px;padding:12px 24px;font-size:13px;font-weight:600;color:var(--text-dim);text-decoration:none;">Cancel</a>
            </div>
        </form>
    </div>
</div>
